# --- Main Dispatch ---

case "$1" in
    setup) cmd_setup ;;
    server)
        case "$2" in
            start) cmd_server_start ;;
            stop)  cmd_server_stop ;;
            status) cmd_status ;;
            *) error "Usage: speakeasy server {start|stop|status}" ;;
        esac
        ;;
    dictate) cmd_dictate ;;
    speak) shift; cmd_speak "$@" ;;
    stop) cmd_stop ;;
    mute)
        if [ -d /tmp/speakeasy-speech.lock ]; then
            cmd_stop; log "Stopped."
        else
            rm -f "$MUTE_FILE"; log "Muted."
        fi
        ;;
    unmute) touch "$MUTE_FILE"; log "Unmuted." ;;
    status) cmd_status ;;
    logs) shift; cmd_logs "$@" ;;
    doctor) cmd_doctor ;;
    hook-install) shift; cmd_hook_install "$@" ;;
    help|*)
        echo "Usage: speakeasy {setup|server|dictate|speak|stop|mute|unmute|status|logs|doctor|hook-install|help}"
        echo "Example logs: speakeasy logs all -n 120"
        echo "Example doctor: speakeasy doctor"
        echo "Example hook-install: speakeasy hook-install {claude|opencode|macos-service}"
        ;;
esac
