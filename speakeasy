#!/usr/bin/env bash

# SpeakEasy - A universal, fully local voice interface for CLI agents.
# STT (whisper.cpp) + TTS (kokoro) + Warm HTTP Servers.
# 100% Private. No Cloud. Just speak.

set -e

# --- Configuration & Paths ---
CONFIG_DIR="$HOME/.config/speakeasy"
DATA_DIR="$HOME/.local/share/speakeasy"
CACHE_DIR="$DATA_DIR/cache"
MODEL_DIR="$DATA_DIR/models"
KOKORO_DIR="$DATA_DIR/kokoro"

CONFIG_FILE="$CONFIG_DIR/config"
MUTE_FILE="$CONFIG_DIR/tts-enabled"
PROJECT_VOICES_FILE="$CONFIG_DIR/project-voices.conf"

WHISPER_PORT=8787
KOKORO_PORT=8788

# Default settings
WHISPER_MODEL="ggml-large-v3-turbo-q5_0.bin"
SILENCE_THRESHOLD="3%"
SILENCE_DURATION="2.0"
RECORD_MAX_DURATION="120"
TTS_VOICE="af_heart"
TTS_SPEED="1.2"
TTS_LANG="en-us"

# Create directories
mkdir -p "$CONFIG_DIR" "$DATA_DIR" "$CACHE_DIR" "$MODEL_DIR" "$KOKORO_DIR"

# Load config if exists
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# --- Helpers ---

log() {
    echo -e "\033[0;35m[speakeasy]\033[0m $1"
}

error() {
    echo -e "\033[0;31m[error]\033[0m $1" >&2
}

is_muted() {
    [ ! -f "$MUTE_FILE" ]
}

is_recording() {
    [ -f "$CACHE_DIR/dictate.pid" ]
}

play_sound() {
    local sound=$1
    case $sound in
        ping)  afplay /System/Library/Sounds/Ping.aiff & ;;
        pop)   afplay /System/Library/Sounds/Pop.aiff & ;;
        glass) afplay /System/Library/Sounds/Glass.aiff & ;;
        basso) afplay /System/Library/Sounds/Basso.aiff & ;;
    esac
}

wait_for_server() {
    local url="$1"
    local name="$2"
    local max_attempts="${3:-60}"
    local i=0
    while ! curl -s "$url" > /dev/null 2>&1; do
        if [ "$i" -ge "$max_attempts" ]; then
            error "$name did not become ready in time"
            return 1
        fi
        sleep 0.5
        i=$((i + 1))
    done
}

get_project_voice() {
    local project_path=$1
    if [ -z "$project_path" ]; then
        echo "$TTS_VOICE"
        return
    fi

    local project_name=$(basename "$project_path")

    if [ -f "$PROJECT_VOICES_FILE" ]; then
        local mapped=$(grep "^$project_name=" "$PROJECT_VOICES_FILE" | cut -d'=' -f2)
        if [ -n "$mapped" ]; then
            echo "$mapped"
            return
        fi

        local default=$(grep "^DEFAULT=" "$PROJECT_VOICES_FILE" | cut -d'=' -f2)
        if [ -n "$default" ]; then
            echo "$default"
            return
        fi
    fi

    echo "$TTS_VOICE"
}

# --- Commands ---

cmd_setup() {
    log "Setting up dependencies..."
    
    # Check for Homebrew
    if ! command -v brew &> /dev/null; then
        error "Homebrew not found. Please install it from https://brew.sh"
        exit 1
    fi
    
    # Install brew deps
    brew install sox ffmpeg jq espeak-ng whisper-cpp
    
    # Install uv if missing
    if ! command -v uv &> /dev/null; then
        log "Installing uv..."
        curl -LsSf https://astral.sh/uv/install.sh | sh
    fi
    
    # Download models
    log "Downloading Whisper model..."
    if [ ! -f "$MODEL_DIR/$WHISPER_MODEL" ]; then
        curl -L "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/$WHISPER_MODEL" -o "$MODEL_DIR/$WHISPER_MODEL"
    fi
    
    log "Downloading Kokoro models..."
    if [ ! -f "$KOKORO_DIR/kokoro-v1.0.onnx" ]; then
        curl -L "https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/kokoro-v1.0.onnx" -o "$KOKORO_DIR/kokoro-v1.0.onnx"
    fi
    if [ ! -f "$KOKORO_DIR/voices-v1.0.bin" ]; then
        curl -L "https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/voices-v1.0.bin" -o "$KOKORO_DIR/voices-v1.0.bin"
    fi
    
    # Deploy tts-server.py
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    if [ -f "$SCRIPT_DIR/tts-server.py" ]; then
        cp "$SCRIPT_DIR/tts-server.py" "$CONFIG_DIR/tts-server.py"
    fi
    chmod +x "$CONFIG_DIR/tts-server.py"
    
    # Default config
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" <<EOF
WHISPER_MODEL="$WHISPER_MODEL"
SILENCE_THRESHOLD="$SILENCE_THRESHOLD"
SILENCE_DURATION="$SILENCE_DURATION"
RECORD_MAX_DURATION="$RECORD_MAX_DURATION"
TTS_VOICE="$TTS_VOICE"
TTS_SPEED="$TTS_SPEED"
TTS_LANG="$TTS_LANG"
EOF
    fi
    
    # Enable TTS by default
    touch "$MUTE_FILE"
    
    log "Setup complete! Run 'speakeasy server start' to begin."
}

cmd_server_start() {
    log "Starting servers..."
    
    # Whisper server
    if ! curl -s "http://127.0.0.1:$WHISPER_PORT/health" > /dev/null; then
        log "Starting whisper-server on port $WHISPER_PORT..."
        whisper-server \
            --model "$MODEL_DIR/$WHISPER_MODEL" \
            --host 127.0.0.1 \
            --port "$WHISPER_PORT" \
            --convert \
            --no-timestamps > "$DATA_DIR/whisper-server.log" 2>&1 &
        echo $! > "$DATA_DIR/server.pid"
    else
        log "Whisper server already running."
    fi
    
    # Kokoro server
    if ! curl -s "http://127.0.0.1:$KOKORO_PORT/health" > /dev/null; then
        log "Starting kokoro-server on port $KOKORO_PORT..."
        uv run --quiet --with kokoro-onnx --with soundfile --with numpy \
            "$CONFIG_DIR/tts-server.py" \
            --host 127.0.0.1 \
            --port "$KOKORO_PORT" \
            --model "$KOKORO_DIR/kokoro-v1.0.onnx" \
            --voices "$KOKORO_DIR/voices-v1.0.bin" > "$DATA_DIR/kokoro-server.log" 2>&1 &
        echo $! > "$DATA_DIR/tts-server.pid"
    else
        log "Kokoro server already running."
    fi
    
    log "Servers warming up. Check 'speakeasy status' in a moment."
}

cmd_server_stop() {
    log "Stopping servers..."
    if [ -f "$DATA_DIR/server.pid" ]; then
        kill $(cat "$DATA_DIR/server.pid") 2>/dev/null || true
        rm "$DATA_DIR/server.pid"
    fi
    if [ -f "$DATA_DIR/tts-server.pid" ]; then
        kill $(cat "$DATA_DIR/tts-server.pid") 2>/dev/null || true
        rm "$DATA_DIR/tts-server.pid"
    fi
    pkill whisper-server || true
    pkill -f tts-server.py || true
    log "Servers stopped."
}

cmd_dictate() {
    local pid_file="$CACHE_DIR/dictate.pid"
    
    if [ -f "$pid_file" ]; then
        # STOP RECORDING
        local pid=$(cat "$pid_file")
        kill "$pid" 2>/dev/null || true
        rm "$pid_file"
        play_sound pop
        
        # Transcribe
        local wav_file="$CACHE_DIR/recording.wav"
        if [ ! -f "$wav_file" ] || [ ! -s "$wav_file" ]; then
            play_sound basso
            exit 0
        fi
        
        # Call whisper-server
        local response=$(curl -s -F "file=@$wav_file" "http://127.0.0.1:$WHISPER_PORT/inference")
        
        # Check if response is valid JSON
        if ! echo "$response" | jq -e . >/dev/null 2>&1; then
             play_sound basso
             exit 0
        fi

        local text=$(echo "$response" | jq -r '.text // empty' 2>/dev/null | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
        
        if [ -z "$text" ] || [ "$text" == "null" ]; then
            play_sound basso
        else
            # Remove trailing newlines/quotes from transcription
            text=$(echo "$text" | tr -d '\n\r' | sed 's/^"//;s/"$//')
            printf "%s" "$text" | pbcopy
            sleep 0.2
            osascript -e 'tell application "System Events" to keystroke "v" using {command down}'
            play_sound glass
        fi
    else
        # START RECORDING
        # Kill any active TTS
        pkill -x afplay || true
        # Release speech lock
        rm -rf /tmp/speakeasy-speech.lock
        
        # Cleanup cache
        rm -f "$CACHE_DIR"/vc_*
        
        play_sound ping
        
        # Ensure server is running (auto-start)
        if ! curl -s "http://127.0.0.1:$WHISPER_PORT/health" > /dev/null; then
            cmd_server_start >/dev/null 2>&1
        fi
        
        # Record using sox (rec)
        rec -q -c 1 -r 16000 "$CACHE_DIR/recording.wav" gain 20 >/dev/null 2>&1 &
        echo $! > "$pid_file"
    fi
}

cmd_stop() {
    pkill -x afplay || true
    if [ -f "$CACHE_DIR/speak.pid" ]; then
        kill "$(cat "$CACHE_DIR/speak.pid")" 2>/dev/null || true
        rm -f "$CACHE_DIR/speak.pid"
    fi
    rm -rf /tmp/speakeasy-speech.lock
}

cmd_speak() {
    local text=""
    local project=""
    
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --project) project="$2"; shift ;;
            *) text="$text $1" ;;
        esac
        shift
    done
    
    if [ -z "$text" ]; then
        text=$(cat)
    fi
    
    if is_muted; then exit 0; fi
    
    # Wait for dictation to finish
    while is_recording; do sleep 0.2; done
    
    # Acquire lock
    until mkdir /tmp/speakeasy-speech.lock 2>/dev/null; do
        if is_recording; then exit 0; fi
        sleep 0.1
    done
    echo $$ > "$CACHE_DIR/speak.pid"
    trap 'rm -rf /tmp/speakeasy-speech.lock; rm -f "$CACHE_DIR/speak.pid"' EXIT
    
    # Strip markdown and code
    local cleaned=$(echo "$text" | sed 's/```[^`]*```//g' | sed 's/`[^`]*`//g' | sed 's/^## *//g' | sed 's/\*\*//g' | sed 's/\*//g' | sed 's/^- //g' | sed 's/^[0-9]*\. //g')
    
    # Normalize PDF hard line breaks (single \n → space, double \n kept as paragraph break)
    # Strip commas from numbers (5,000 → 5000 so TTS says "five thousand" not "five zero zero zero")
    # then split into sentences so each TTS chunk is a full sentence, not a physical line
    local sentences=$(python3 -c "
import sys, re
text = sys.stdin.read()
text = re.sub(r'(\w)-\n(\w)', r'\1\2', text)
text = re.sub(r'\n{2,}', '\n\n', text)
text = re.sub(r'(?<!\n)\n(?!\n)', ' ', text)
text = re.sub(r'(?<=\d),(?=\d{3})', '', text)
text = re.sub(r'(\d)\.(\d)', r'\1 point \2', text)
parts = re.split(r'(?<=[.!?])\s+', text)
print('\n'.join(s.strip() for s in parts if s.strip()))
" <<< "$cleaned")
    
    local voice=$(get_project_voice "$project")

    # Auto-start servers if not running, then wait for Kokoro to be ready
    if ! curl -s "http://127.0.0.1:$KOKORO_PORT/health" > /dev/null 2>&1; then
        cmd_server_start >/dev/null 2>&1
        wait_for_server "http://127.0.0.1:$KOKORO_PORT/health" "Kokoro" || return 1
    fi

    # Chunked streaming
    while IFS= read -r line; do
        if [ -z "$line" ]; then continue; fi
        if is_muted || is_recording; then break; fi

        local temp_wav="$CACHE_DIR/vc_$(date +%s%N).wav"

        curl -s -X POST "http://127.0.0.1:$KOKORO_PORT/speak" \
            -H "Content-Type: application/json" \
            -d "{\"text\": \"$(echo "$line" | sed 's/"/\\"/g')\", \"voice\": \"$voice\", \"speed\": $TTS_SPEED}" \
            --output "$temp_wav"

        # Play (|| true so a SIGTERM from mute/dictate doesn't trip set -e)
        if [ -f "$temp_wav" ]; then
            if ! is_muted && ! is_recording; then
                afplay "$temp_wav" || true
            fi
            rm "$temp_wav"
        fi

    done <<< "$sentences"
}

cmd_status() {
    echo "--- SpeakEasy Status ---"
    if is_muted; then
        echo -e "TTS: \033[0;31mMUTED\033[0m"
    else
        echo -e "TTS: \033[0;32mENABLED\033[0m"
    fi
    
    if curl -s "http://127.0.0.1:$WHISPER_PORT/health" > /dev/null; then
        echo -e "Whisper Server: \033[0;32mRUNNING\033[0m (port $WHISPER_PORT)"
    else
        echo -e "Whisper Server: \033[0;31mSTOPPED\033[0m"
    fi
    
    if curl -s "http://127.0.0.1:$KOKORO_PORT/health" > /dev/null; then
        echo -e "Kokoro Server: \033[0;32mRUNNING\033[0m (port $KOKORO_PORT)"
    else
        echo -e "Kokoro Server: \033[0;31mSTOPPED\033[0m"
    fi
    
    echo "Config: $CONFIG_FILE"
    echo "Models: $MODEL_DIR"
}

cmd_logs() {
    local target="all"
    local lines=80

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            -n|--lines)
                lines="${2:-80}"
                shift
                ;;
            whisper|kokoro|opencode|all)
                target="$1"
                ;;
            *)
                error "Usage: speakeasy logs [whisper|kokoro|opencode|all] [-n LINES]"
                return 1
                ;;
        esac
        shift
    done

    local showed=0
    show_log() {
        local name="$1"
        local file="$2"
        if [ -f "$file" ]; then
            echo "--- $name ($file) ---"
            tail -n "$lines" "$file"
            echo
            showed=1
        fi
    }

    case "$target" in
        whisper)
            show_log "Whisper" "$DATA_DIR/whisper-server.log"
            ;;
        kokoro)
            show_log "Kokoro" "$DATA_DIR/kokoro-server.log"
            ;;
        opencode)
            show_log "OpenCode Plugin" "/tmp/opencode_plugin.log"
            ;;
        all)
            show_log "Whisper" "$DATA_DIR/whisper-server.log"
            show_log "Kokoro" "$DATA_DIR/kokoro-server.log"
            show_log "OpenCode Plugin" "/tmp/opencode_plugin.log"
            ;;
    esac

    if [ "$showed" -eq 0 ]; then
        log "No logs found for target: $target"
    fi
}

cmd_doctor() {
    local failures=0
    local warnings=0

    ok() { echo -e "\033[0;32m[ok]\033[0m $1"; }
    warn() { echo -e "\033[0;33m[warn]\033[0m $1"; warnings=$((warnings + 1)); }
    fail() { echo -e "\033[0;31m[fail]\033[0m $1"; failures=$((failures + 1)); }

    check_cmd() {
        local cmd="$1"
        if command -v "$cmd" >/dev/null 2>&1; then
            ok "Command available: $cmd"
        else
            fail "Missing command: $cmd"
        fi
    }

    check_file() {
        local file="$1"
        local label="$2"
        if [ -f "$file" ]; then
            ok "$label present: $file"
        else
            fail "$label missing: $file"
        fi
    }

    check_http() {
        local name="$1"
        local url="$2"
        if curl -s "$url" >/dev/null 2>&1; then
            ok "$name reachable ($url)"
        else
            warn "$name not reachable ($url)"
        fi
    }

    echo "--- SpeakEasy Doctor ---"
    echo "Config: $CONFIG_FILE"
    echo "Data:   $DATA_DIR"
    echo

    check_cmd sox
    check_cmd ffmpeg
    check_cmd jq
    check_cmd whisper-server
    check_cmd uv
    check_cmd curl
    check_cmd python3
    echo

    check_file "$CONFIG_FILE" "Config file"
    check_file "$CONFIG_DIR/tts-server.py" "TTS server script"
    check_file "$MODEL_DIR/$WHISPER_MODEL" "Whisper model"
    check_file "$KOKORO_DIR/kokoro-v1.0.onnx" "Kokoro model"
    check_file "$KOKORO_DIR/voices-v1.0.bin" "Kokoro voices"
    echo

    if is_muted; then
        warn "TTS is muted (run: speakeasy unmute)"
    else
        ok "TTS is enabled"
    fi
    check_http "Whisper server" "http://127.0.0.1:$WHISPER_PORT/health"
    check_http "Kokoro server" "http://127.0.0.1:$KOKORO_PORT/health"
    echo

    local claude_settings="$HOME/.claude/settings.json"
    if [ -f "$claude_settings" ] && jq -e '.hooks.Stop and .hooks.Notification' "$claude_settings" >/dev/null 2>&1; then
        ok "Claude hooks configured"
    else
        warn "Claude hooks not configured (run: speakeasy hook-install claude)"
    fi

    local opencode_config="$HOME/.config/opencode/opencode.json"
    local opencode_plugin="$HOME/.config/opencode/plugins/speakeasy.ts"
    if [ -f "$opencode_plugin" ]; then
        ok "OpenCode plugin file present"
    else
        warn "OpenCode plugin file missing (run: speakeasy hook-install opencode)"
    fi
    if [ -f "$opencode_config" ] && jq -e --arg p "file://$opencode_plugin" '.plugin // [] | index($p)' "$opencode_config" >/dev/null 2>&1; then
        ok "OpenCode config references SpeakEasy plugin"
    else
        warn "OpenCode config missing SpeakEasy plugin reference"
    fi

    local macos_speak="$HOME/Library/Services/Speak with SpeakEasy.workflow"
    local macos_stop="$HOME/Library/Services/Stop SpeakEasy.workflow"
    if [ -d "$macos_speak" ] && [ -d "$macos_stop" ]; then
        ok "macOS services installed (Speak + Stop)"
    elif [ -d "$macos_speak" ]; then
        warn "macOS Stop service missing (run: speakeasy hook-install macos-service)"
    else
        warn "macOS services not installed (run: speakeasy hook-install macos-service)"
    fi
    echo

    echo "Summary: $failures fail, $warnings warn"
    if [ "$failures" -gt 0 ]; then
        return 1
    fi
}

cmd_hook_install() {
    local target="${1:-claude}"
    log "Installing hooks for $target..."
    
    mkdir -p "$CONFIG_DIR"
    local speakeasy_bin="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

    case "$target" in
        claude)
            # Create stop hook
            cat > "$CONFIG_DIR/claude-hook-stop.sh" <<EOF
#!/usr/bin/env bash
INPUT=\$(cat)
RAW=\$(echo "\$INPUT" | jq -r '.last_assistant_message // empty' 2>/dev/null)
[ -z "\$RAW" ] && exit 0
CWD=\$(echo "\$INPUT" | jq -r '.cwd // empty' 2>/dev/null)
MSG=\$(echo "\$RAW" | sed 's/\`\`\`[^\`]*\`\`\`//g' | sed 's/\`[^\`]*\`//g' | sed 's/^## *//g' | sed 's/\*\*//g' | sed 's/\*//g' | sed 's/^- //g' | sed 's/^[0-9]*\. //g')
TRIMMED=\$(echo "\$MSG" | tr -d '[:space:]')
[ \${#TRIMMED} -lt 10 ] && exit 0
MAX=2000
if [ \${#MSG} -gt \$MAX ]; then MSG="\${MSG:0:\$MAX}..."; fi
if [ -n "\$CWD" ]; then
    "$speakeasy_bin" speak --project "\$CWD" "\$MSG" &
else
    "$speakeasy_bin" speak "\$MSG" &
fi
exit 0
EOF
            chmod +x "$CONFIG_DIR/claude-hook-stop.sh"

            # Create notify hook
            cat > "$CONFIG_DIR/claude-hook-notify.sh" <<EOF
#!/usr/bin/env bash
INPUT=\$(cat)
MSG=\$(echo "\$INPUT" | jq -r '.message // empty' 2>/dev/null)
[ -z "\$MSG" ] && exit 0
CWD=\$(echo "\$INPUT" | jq -r '.cwd // empty' 2>/dev/null)
if [ -n "\$CWD" ]; then
    "$speakeasy_bin" speak --project "\$CWD" "\$MSG" &
else
    "$speakeasy_bin" speak "\$MSG" &
fi
exit 0
EOF
            chmod +x "$CONFIG_DIR/claude-hook-notify.sh"

            # Update Claude settings
            local settings="$HOME/.claude/settings.json"
            if [ ! -f "$settings" ]; then
                mkdir -p "$HOME/.claude"
                echo "{}" > "$settings"
            fi
            
            local tmp_settings=$(mktemp)
            jq --arg stop "$CONFIG_DIR/claude-hook-stop.sh" \
               --arg notify "$CONFIG_DIR/claude-hook-notify.sh" \
               '.hooks = {
                 "Notification": [{
                   "matcher": "*",
                   "hooks": [{"type": "command", "command": ("cat | " + $notify), "async": true}]
                 }],
                 "Stop": [{
                   "matcher": "*",
                   "hooks": [{"type": "command", "command": ("cat | " + $stop), "async": true}]
                 }]
               }' \
               "$settings" > "$tmp_settings" && mv "$tmp_settings" "$settings"
            
            log "Claude hooks installed to $settings. Please restart Claude Code."
            ;;
        opencode)
            local opencode_config_dir="$HOME/.config/opencode"
            local opencode_plugin_dir="$opencode_config_dir/plugins"
            local opencode_plugin_file="$opencode_plugin_dir/speakeasy.ts"
            local opencode_config_file="$opencode_config_dir/opencode.json"
            local speakeasy_bin_json
            local tmp_config
            mkdir -p "$opencode_plugin_dir"
            speakeasy_bin_json=$(jq -Rn --arg v "$speakeasy_bin" '$v')
            cat > "$opencode_plugin_file" <<'EOF'
import type { Plugin } from "@opencode-ai/plugin";
import fs from "node:fs";
import { spawn } from "node:child_process";

const log = (message: string) => {
  fs.appendFileSync("/tmp/opencode_plugin.log", `[${new Date().toISOString()}] ${message}\n`);
};

const cleanText = (text: string): string =>
  text
    .replace(/```[\s\S]*?```/g, " ")
    .replace(/`[^`]*`/g, " ")
    .replace(/\s+/g, " ")
    .trim();

const plugin: Plugin = async () => {
  log("SpeakEasy Plugin Loaded!");

  const speakeasy_bin = __SPEAKEASY_BIN__;
  let lastSpoken = "";
  let lastSpokenMessageID = "";
  const assistantMessageIDs = new Set<string>();

  const speakIfUseful = (raw: string) => {
    const text = cleanText(raw);
    if (text.length < 3 || text === lastSpoken) return;
    lastSpoken = text;

    try {
      const child = spawn(speakeasy_bin, ["speak", "--project", process.cwd(), text], {
        detached: true,
        stdio: "ignore"
      });
      child.unref();
      log(`Spoke assistant message (${text.length} chars).`);
    } catch {}
  };

  return {
    event: async ({ event }) => {
      const type = String((event as { type?: unknown })?.type ?? "");
      if (type === "message.updated") {
        const e = event as { properties?: { info?: { id?: string; role?: string } } };
        const messageID = e.properties?.info?.id ?? "";
        const role = e.properties?.info?.role ?? "";
        if (messageID && role === "assistant") {
          assistantMessageIDs.add(messageID);
        }
        return;
      }
      if (type !== "message.part.updated") return;

      const e = event as {
        properties?: {
          part?: {
            type?: string;
            text?: string;
            messageID?: string;
          };
        };
      };

      const part = e.properties?.part;
      if (!part || part.type !== "text") return;

      const messageID = part.messageID ?? "";
      const text = cleanText(part.text ?? "");
      if (text.length < 3) return;
      if (!messageID || !assistantMessageIDs.has(messageID)) return;
      if (messageID && messageID === lastSpokenMessageID && text === lastSpoken) return;

      lastSpokenMessageID = messageID;
      speakIfUseful(text);
    }
  };
};

export const SpeakEasyPlugin = plugin;
EOF
            sed -i '' "s|__SPEAKEASY_BIN__|$speakeasy_bin_json|g" "$opencode_plugin_file"

            if [ ! -f "$opencode_config_file" ]; then
